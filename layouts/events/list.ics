BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//freifunk berlin//hugo wegbsite generator//EN
CALSCALE:GREGORIAN
BEGIN:VTIMEZONE
TZID:Europe/Berlin
BEGIN:STANDARD
TZNAME:CET
TZOFFSETFROM:+0200
TZOFFSETTO:+0100
END:STANDARD
END:VTIMEZONE
{{- range .Pages }}
{{- $description := .Content | plainify }}
{{- $description :=  replace $description "\n" " " }}
{{- $description := strings.TrimSpace $description }}
BEGIN:VEVENT
DTSTAMP;VALUE=DATE-TIME:{{ dateFormat "20060102T150405Z" .Date }}
LOCATION:{{ .Params.location }}
CATEGORIES:{{ .Params.category }}
SEQUENCE:0
CLASS:PUBLIC
SUMMARY:{{ .Title }}
DESCRIPTION;ENCODING=QUOTED-PRINTABLE: {{ substr $description 0 36 }}
{{- $description := split (substr $description 37) "" }}
{{- range ($description | len) }}
{{- if eq (mod . 74) 0 }}
 {{ index $description . }}
{{- else }}
{{- index $description . }}
{{- end }}
{{- end }}
UID:{{ .Params.start }}@berlin.freifunk.net
TZID:Europe/Berlin
DTSTART;TZID=Europe/Berlin;VALUE=DATE-TIME:{{ dateFormat "20060102T150405" .Params.start }}
DTEND;TZID=Europe/Berlin;VALUE=DATE-TIME:{{ dateFormat "20060102T150405" .Params.end }}
{{- if .Params.rrule }}
RRULE:{{ .Params.rrule }}
{{- end }}
URL:{{ .Permalink }}
BEGIN:VALARM
TRIGGER:-PT60M
ACTION:DISPLAY
DESCRIPTION:{{ .Title }}
END:VALARM
END:VEVENT
{{- end }}
END:VCALENDAR
